# Middleware для автоматической регистрации пользователей
async def register_user_middleware(handler, event: types.Message, data: dict):
    """Автоматически инициализирует user_data при первом обращении пользователя"""
    try:
        user = event.from_user
        if user:
            user_id = user.id
            if user_id not in user_data:
                user_data[user_id] = {
                    'username': user.username or '',
                    'first_name': user.first_name or '',
                    'last_name': user.last_name or '',
                    'user_name': user.username or user.first_name or str(user_id),
                    'user_id': user_id,
                    'language_code': user.language_code or '',
                    'is_premium': user.is_premium or False,
                    'is_bot': user.is_bot or False,
                }
{%- if userDatabaseEnabled %}
                # Получаем file_id аватарки пользователя (не URL — он временный)
                _avatar_url = None
                try:
                    _photos = await bot.get_user_profile_photos(user_id, limit=1)
                    if _photos and _photos.photos:
                        # Сохраняем file_id — он постоянный, в отличие от file_path
                        _avatar_url = _photos.photos[0][-1].file_id
                        logging.info(f"✅ Аватарка (file_id) получена для {user_id}")
                    else:
                        logging.info(f"ℹ️ У пользователя {user_id} нет аватарки")
                except Exception as _e:
                    logging.warning(f"⚠️ Не удалось получить аватарку для {user_id}: {_e}")
                await save_user_to_db(
                    user_id, user.username, user.first_name, user.last_name, _avatar_url,
                    is_premium=user_data[user_id].get('is_premium', False),
                    is_bot=user_data[user_id].get('is_bot', False),
                    language_code=user_data[user_id].get('language_code'),
                )
{%- endif %}
                logging.info(f"Новый пользователь зарегистрирован: {user_id}")
    except Exception as e:
        logging.error(f"Ошибка в register_user_middleware: {e}")

    return await handler(event, data)

{% endif %}

