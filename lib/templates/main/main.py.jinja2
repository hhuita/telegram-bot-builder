{#
  Запуск бота

  @fileoverview Главная функция main() и запуск поллинга
  @param {boolean} userDatabaseEnabled - Включена ли база данных пользователей (для инициализации БД)
  @param {boolean} hasInlineButtons - Есть ли inline кнопки (для callback middleware)
  @param {list} menuCommands - Список команд меню [{command, description}]
#}
{% if menuCommands and menuCommands | length > 0 %}
async def set_bot_commands():
    """Настройка меню команд для BotFather"""
    commands = [
{% for cmd in menuCommands %}
        BotCommand(command="{{ cmd.command }}", description="{{ cmd.description }}"),
{% endfor %}
    ]
    await bot.set_my_commands(commands)

{% endif %}

async def main():
    """Главная функция запуска бота"""
    global db_pool, dp, _redis_client, _redis_connected

    _stop_event = asyncio.Event()
    _lock_acquired = False

    def signal_handler(signum, _frame):
        print(f"⚠️ Получен сигнал {signum}, начинаем корректное завершение...")
        _stop_event.set()

    signal.signal(signal.SIGTERM, signal_handler)
    signal.signal(signal.SIGINT, signal_handler)

    try:
        # Инициализация Redis клиента (если REDIS_URL задан)
        _redis_connected = await init_redis_client()
        
        # Если Redis успешно подключился — переключаем storage у уже созданного Dispatcher
        if _redis_connected and _redis_client is not None:
            dp.fsm.storage = RedisStorage(_redis_client)
            logging.info("🔴 FSM хранилище: Redis")
        else:
            logging.info("🐘 FSM хранилище: PostgreSQL")

        # Distributed lock через Redis — защита от двойного запуска (только в polling режиме)
        # В webhook режиме двойной запуск невозможен — Telegram шлёт апдейты на один URL
        if not WEBHOOK_URL and _redis_connected and _redis_client is not None:
            _lock_key = f"bot:lock:{BOT_TOKEN[-10:]}"
            _lock_acquired = await _redis_client.set(_lock_key, "1", nx=True, ex=60)
            if not _lock_acquired:
                logging.warning("⚠️ Бот уже запущен (Redis lock занят). Завершаем дублирующий процесс.")
                return
            logging.info("🔒 Redis lock получен — бот запускается")

            # Фоновая задача: обновляем lock каждые 30 секунд пока бот работает
            async def _refresh_lock():
                while True:
                    await asyncio.sleep(30)
                    try:
                        await _redis_client.expire(_lock_key, 60)
                    except Exception:
                        pass

            asyncio.create_task(_refresh_lock())

        # Публикуем событие о запуске бота в Redis (если доступен)
        if _redis_connected and _redis_client is not None:
            try:
                import json as _json
                await _redis_client.publish(
                    f"bot:started:{PROJECT_ID}:{TOKEN_ID}",
                    _json.dumps({"projectId": PROJECT_ID, "tokenId": TOKEN_ID, "timestamp": __import__('datetime').datetime.now().isoformat()})
                )
            except Exception:
                pass

        {%- if userDatabaseEnabled %}
        await init_database()
        {%- endif %}

        # Загружаем кэш Telegram file_id из БД в память — чтобы после перезапуска не читать файлы заново
        if db_pool:
            try:
                async with db_pool.acquire() as _conn:
                    _rows = await _conn.fetch(
                        "SELECT url, telegram_file_id FROM media_files WHERE project_id = $1 AND telegram_file_id IS NOT NULL",
                        PROJECT_ID
                    )
                    for _row in _rows:
                        _media_file_id_cache[_row["url"]] = _row["telegram_file_id"]
                    if _rows:
                        logging.info(f"📦 Загружено {len(_rows)} file_id из БД в кэш памяти")
            except Exception as _cache_err:
                logging.warning(f"⚠️ Не удалось загрузить file_id кэш из БД: {_cache_err}")

        {%- if menuCommands and menuCommands | length > 0 %}
        await set_bot_commands()
        {%- endif %}

        {# Фильтр устаревших апдейтов — регистрируем первым чтобы отсеивать до всей логики #}
        dp.message.middleware(stale_update_filter_middleware)

        {%- if userDatabaseEnabled %}
        dp.message.middleware(message_logging_middleware)
        dp.message.outer_middleware(BotOutgoingLoggingMiddleware())
        _wrap_bot_send_message(bot)
        _wrap_bot_send_photo(bot)
        _wrap_bot_send_video(bot)
        _wrap_bot_send_audio(bot)
        _wrap_bot_send_document(bot)
        _wrap_message_answer(bot)
        _wrap_bot_send_sticker(bot)
        _wrap_bot_send_voice(bot)
        _wrap_bot_send_animation(bot)
        _wrap_bot_send_media_group(bot)
        {%- if hasInlineButtons %}
        dp.callback_query.middleware(callback_query_logging_middleware)
        {%- endif %}
        {%- endif %}

        {%- if autoRegisterUsers %}
        dp.message.middleware(register_user_middleware)
        {%- endif %}

        {%- if incomingMessageTriggerMiddlewares and incomingMessageTriggerMiddlewares | length > 0 %}
        {%- for mw in incomingMessageTriggerMiddlewares %}
        dp.message.middleware({{ mw }})
        {%- endfor %}
        {%- endif %}

        {%- if managedBotUpdatedTriggerMiddlewares and managedBotUpdatedTriggerMiddlewares | length > 0 %}
        {%- for mw in managedBotUpdatedTriggerMiddlewares %}
        dp.message.middleware({{ mw }})
        {%- endfor %}
        {%- endif %}

        # Запускаем фоновую задачу TTL-очистки user_data
        asyncio.create_task(cleanup_user_data())

        # Выбор режима запуска: webhook или polling
        if WEBHOOK_URL:
            # Webhook режим — запускаем aiohttp сервер
            from aiohttp import web
            from aiogram.webhook.aiohttp_server import SimpleRequestHandler, setup_application

            webhook_path = f"/api/webhook/{PROJECT_ID}/{TOKEN_ID}"
            full_webhook_url = f"{WEBHOOK_URL.rstrip('/')}{webhook_path}"

            logging.info(f"🌐 Webhook режим: {full_webhook_url}")
            logging.info(f"🔌 Порт aiohttp: {WEBHOOK_PORT}")

            await bot.set_webhook(full_webhook_url)

            app = web.Application()
            SimpleRequestHandler(dispatcher=dp, bot=bot).register(app, path="/webhook")
            setup_application(app, dp, bot=bot)

            runner = web.AppRunner(app)
            await runner.setup()
            site = web.TCPSite(runner, host="0.0.0.0", port=WEBHOOK_PORT)
            await site.start()

            logging.info(f"✅ Webhook сервер запущен на порту {WEBHOOK_PORT}")
            await _stop_event.wait()

            await runner.cleanup()
            await bot.delete_webhook()
        else:
            # Polling режим — стандартный запуск
            logging.info("🔄 Polling режим")
            # Запускаем polling и ждём сигнала остановки
            polling_task = asyncio.create_task(dp.start_polling(bot))
            await _stop_event.wait()
            await dp.stop_polling()
            await polling_task
    except KeyboardInterrupt:
        print("⚠️ Получен сигнал остановки, завершаем работу...")
    except SystemExit:
        print("⚠️ Системное завершение, завершаем работу...")
    except Exception as e:
        logging.error(f"Ошибка: {e}")
    finally:
        {%- if userDatabaseEnabled %}
        if db_pool:
            await db_pool.close()
        {%- endif %}

        # Освобождаем Redis lock при завершении (только в polling режиме — в webhook lock не устанавливался)
        if not WEBHOOK_URL and _redis_connected and _redis_client is not None and _lock_acquired:
            try:
                await _redis_client.delete(f"bot:lock:{BOT_TOKEN[-10:]}")
                logging.info("🔓 Redis lock освобождён")
            except Exception:
                pass

        # Публикуем событие об остановке бота в Redis (если доступен)
        if _redis_connected and _redis_client is not None:
            try:
                import json as _json
                await _redis_client.publish(
                    f"bot:stopped:{PROJECT_ID}:{TOKEN_ID}",
                    _json.dumps({"projectId": PROJECT_ID, "tokenId": TOKEN_ID, "timestamp": __import__('datetime').datetime.now().isoformat()})
                )
            except Exception:
                pass

        await bot.session.close()


if __name__ == "__main__":
    asyncio.run(main())
