{#
  Получение московского времени
#}
{% macro get_moscow_time_macro() %}
def get_moscow_time():
    """Получает текущее время в Москве"""
    from datetime import datetime, timezone, timedelta
    moscow_tz = timezone(timedelta(hours=3))
    return datetime.now(moscow_tz).strftime("%Y-%m-%d %H:%M:%S")
{% endmacro %}

{#
  Логирование сообщений
  @param hasMessageLogging - флаг наличия логирования
#}
{% macro log_message_function() %}
async def log_message(user_id: int, message_type: str, message_text: str = None, message_data: str = None, node_id: str = None):
    """Логирует сообщения в базу данных"""
    if not db_pool:
        return
    try:
        async with db_pool.acquire() as conn:
            await conn.execute(
                "INSERT INTO bot_messages (project_id, token_id, user_id, message_type, message_text, message_data, node_id, created_at) VALUES ($1, $2, $3, $4, $5, $6, $7, NOW())",
                PROJECT_ID, TOKEN_ID, user_id, message_type, message_text, message_data, node_id
            )
    except Exception as e:
        logging.error(f"❌ Ошибка логирования сообщения: {e}")
{% endmacro %}

{#
  Получение списка user_ids
#}
{% macro get_user_ids_from_db() %}
async def get_user_ids_from_db(user_id: int):
    """Получает список user_ids из таблицы user_ids"""
    if not db_pool:
        return {"user_ids": [], "count": 0}
    try:
        async with db_pool.acquire() as conn:
            rows = await conn.fetch("SELECT user_id FROM user_ids ORDER BY created_at DESC")
            user_ids = [str(row["user_id"]) for row in rows]
            count = len(rows)
            logging.info(f"✅ Получено {count} ID из таблицы user_ids")
            return {"user_ids": user_ids, "count": count}
    except Exception as e:
        logging.error(f"❌ Ошибка получения данных из user_ids: {e}")
        return {"user_ids": [], "count": 0}
{% endmacro %}

{#
  Получение данных пользователя
#}
{% macro get_user_data_from_db() %}
async def get_user_data_from_db(user_id: int, data_key: str):
    """Получает конкретное поле из user_data"""
    if not db_pool:
        return None
    try:
        async with db_pool.acquire() as conn:
            row = await conn.fetchrow("SELECT user_data FROM bot_users WHERE user_id = $1 AND project_id = $2 AND token_id = $3", user_id, PROJECT_ID, TOKEN_ID)
            if row and row["user_data"]:
                user_data = row["user_data"]
                if isinstance(user_data, str):
                    try:
                        data = json.loads(user_data)
                        return data.get(data_key)
                    except (json.JSONDecodeError, TypeError):
                        return None
                elif isinstance(user_data, dict):
                    return user_data.get(data_key)
    except Exception as e:
        logging.error(f"❌ Ошибка получения данных из БД: {e}")
    return None
{% endmacro %}

{#
  Обновление переменной пользователя
#}
{% macro update_user_variable_in_db() %}
async def update_user_variable_in_db(user_id: int, variable_name: str, variable_value):
    """Обновляет конкретную переменную в user_data"""
    if not db_pool:
        return False
    try:
        async with db_pool.acquire() as conn:
            row = await conn.fetchrow("SELECT user_data FROM bot_users WHERE user_id = $1 AND project_id = $2 AND token_id = $3", user_id, PROJECT_ID, TOKEN_ID)
            if row and row["user_data"]:
                user_data = row["user_data"]
                if isinstance(user_data, str):
                    try:
                        user_data = json.loads(user_data)
                    except (json.JSONDecodeError, TypeError):
                        user_data = {}
                elif not isinstance(user_data, dict):
                    user_data = {}
            else:
                user_data = {}
            
            user_data[variable_name] = variable_value
            
            await conn.execute(
                "UPDATE bot_users SET user_data = $1 WHERE user_id = $2 AND project_id = $3 AND token_id = $4",
                json.dumps(user_data, ensure_ascii=False), user_id, PROJECT_ID, TOKEN_ID
            )
            logging.info(f"✅ Переменная '{variable_name}' обновлена в БД")
            return True
    except Exception as e:
        logging.error(f"❌ Ошибка обновления переменной в БД: {e}")
        return False
{% endmacro %}

{#
  Алиас для update_user_data_in_db
#}
{% macro save_user_data_to_db() %}
async def save_user_data_to_db(user_id: int, variable_name: str, variable_value):
    """Алиас для update_user_variable_in_db (для обратной совместимости)"""
    return await update_user_variable_in_db(user_id, variable_name, variable_value)
{% endmacro %}

{%- if userDatabaseEnabled %}
async def init_database():
    """Инициализация подключения к базе данных и создание таблиц"""
    global db_pool
    try:
        db_pool = await asyncpg.create_pool(DATABASE_URL, min_size=1, max_size=10)
        async with db_pool.acquire() as conn:
            await conn.execute("""
                CREATE TABLE IF NOT EXISTS bot_users (
                    user_id BIGINT NOT NULL,
                    project_id INTEGER NOT NULL DEFAULT 0,
                    token_id INTEGER NOT NULL DEFAULT 0,
                    username TEXT,
                    first_name TEXT,
                    last_name TEXT,
                    avatar_url TEXT,
                    registered_at TIMESTAMP DEFAULT NOW(),
                    last_interaction TIMESTAMP DEFAULT NOW(),
                    interaction_count INTEGER DEFAULT 0,
                    user_data JSONB DEFAULT '{}',
                    is_active BOOLEAN DEFAULT TRUE,
                    PRIMARY KEY (user_id, project_id, token_id)
                );
            """)
            await conn.execute("""
                CREATE TABLE IF NOT EXISTS bot_messages (
                    id SERIAL PRIMARY KEY,
                    project_id INTEGER,
                    token_id INTEGER NOT NULL DEFAULT 0,
                    user_id BIGINT,
                    message_type VARCHAR(50),
                    message_text TEXT,
                    message_data JSONB DEFAULT '{}',
                    node_id VARCHAR(255),
                    created_at TIMESTAMP DEFAULT NOW()
                )
            """)
            logging.info("✅ Таблица bot_messages создана")
{%- if hasTelegramSettingsTable %}
            await conn.execute("""
                CREATE TABLE IF NOT EXISTS user_telegram_settings (
                    user_id BIGINT PRIMARY KEY,
                    api_id TEXT,
                    api_hash TEXT,
                    phone_number TEXT,
                    session_string TEXT,
                    is_active BOOLEAN DEFAULT TRUE,
                    created_at TIMESTAMP DEFAULT NOW()
                );
            """)
            logging.info("✅ Таблица user_telegram_settings создана")
{%- endif %}
        logging.info("✅ База данных инициализирована")
    except Exception as e:
        logging.warning(f"⚠️ Не удалось подключиться к БД: {e}. Используем локальное хранилище.")
        db_pool = None


async def save_user_to_db(user_id: int, username: str = None, first_name: str = None,
                          last_name: str = None, avatar_url: str = None,
                          is_premium: bool = False, is_bot: bool = False,
                          language_code: str = None, deep_link_param: str = None,
                          referrer_id: str = None):
    """Сохраняет пользователя в БД и публикует событие new-user в Redis при первом визите.

    deep_link_param и referrer_id не перезаписываются при повторных визитах —
    сохраняется только значение первого касания (COALESCE).
    """
    from datetime import datetime
    if not db_pool:
        return False
    try:
        async with db_pool.acquire() as conn:
            result = await conn.fetchrow("""
                INSERT INTO bot_users (
                    user_id, project_id, token_id, username, first_name, last_name,
                    avatar_url, interaction_count, is_premium, is_bot,
                    language_code, deep_link_param, referrer_id
                )
                VALUES ($1, $2, $3, $4, $5, $6, $7, 1, $8, $9, $10, $11, $12)
                ON CONFLICT (user_id, project_id, token_id) DO UPDATE SET
                    username = EXCLUDED.username,
                    first_name = EXCLUDED.first_name,
                    last_name = EXCLUDED.last_name,
                    avatar_url = COALESCE(EXCLUDED.avatar_url, bot_users.avatar_url),
                    is_premium = EXCLUDED.is_premium,
                    is_bot = EXCLUDED.is_bot,
                    language_code = COALESCE(EXCLUDED.language_code, bot_users.language_code),
                    deep_link_param = COALESCE(bot_users.deep_link_param, EXCLUDED.deep_link_param),
                    referrer_id = COALESCE(bot_users.referrer_id, EXCLUDED.referrer_id),
                    last_interaction = NOW(),
                    interaction_count = bot_users.interaction_count + 1
                RETURNING xmax
            """, user_id, PROJECT_ID, TOKEN_ID, username, first_name, last_name,
                avatar_url, 1 if is_premium else 0, 1 if is_bot else 0,
                language_code, deep_link_param, referrer_id)

        # xmax = 0 означает INSERT (новый пользователь), >0 — UPDATE (существующий)
        is_new_user = result is not None and result['xmax'] == 0

        if is_new_user:
            logging.info(f"🆕 Новый пользователь: {user_id} (@{username})")
        else:
            logging.debug(f"👤 Существующий пользователь: {user_id} (interaction_count обновлён)")

        if is_new_user and _redis_client:
            try:
                _new_user_payload = json.dumps({
                    "userId": str(user_id),
                    "username": username,
                    "firstName": first_name,
                    "lastName": last_name,
                    "avatarUrl": avatar_url,
                    "isBot": 1 if is_bot else 0,
                    "isPremium": 1 if is_premium else 0,
                    "languageCode": language_code,
                    "deepLinkParam": deep_link_param,
                    "referrerId": referrer_id,
                    "registeredAt": datetime.utcnow().isoformat(),
                }, ensure_ascii=False)
                await _redis_client.publish(
                    f"bot:user:{PROJECT_ID}:{TOKEN_ID}",
                    _new_user_payload
                )
                logging.info(f"📡 Redis publish: bot:user:{PROJECT_ID}:{TOKEN_ID} | user={user_id} @{username}")
            except Exception as _re:
                logging.warning(f"⚠️ Redis publish bot:user не удался: {_re}")
        elif is_new_user and not _redis_client:
            logging.warning(f"⚠️ Redis недоступен — событие bot:user не опубликовано (user={user_id})")

        return True
    except Exception as e:
        logging.error(f"Ошибка сохранения пользователя в БД: {e}")
        return False


async def get_user_from_db(user_id: int):
    """Получает данные пользователя из базы данных"""
    if not db_pool:
        return None
    try:
        async with db_pool.acquire() as conn:
            row = await conn.fetchrow("SELECT * FROM bot_users WHERE user_id = $1 AND project_id = $2 AND token_id = $3", user_id, PROJECT_ID, TOKEN_ID)
            if row:
                row_dict = {key: row[key] for key in row.keys()}
                if "user_data" in row_dict and row_dict["user_data"]:
                    user_data = row_dict["user_data"]
                    if isinstance(user_data, str):
                        try:
                            return json.loads(user_data)
                        except (json.JSONDecodeError, TypeError):
                            return {}
                    elif isinstance(user_data, dict):
                        return user_data
                return row_dict
        return None
    except Exception as e:
        logging.error(f"Ошибка получения пользователя из БД: {e}")
        return None


async def update_user_data_in_db(user_id: int, data_key: str, data_value):
    """Обновляет пользовательские данные в базе данных"""
    if not db_pool:
        return False
    try:
        async with db_pool.acquire() as conn:
            await conn.execute("""
                INSERT INTO bot_users (user_id, project_id, token_id)
                VALUES ($1, $2, $3)
                ON CONFLICT (user_id, project_id, token_id) DO NOTHING
            """, user_id, PROJECT_ID, TOKEN_ID)

            update_data = {data_key: data_value}
            await conn.execute("""
                UPDATE bot_users
                SET user_data = COALESCE(user_data, '{}'::jsonb) || $2::jsonb,
                    last_interaction = NOW()
                WHERE user_id = $1 AND project_id = $3 AND token_id = $4
            """, user_id, json.dumps(update_data), PROJECT_ID, TOKEN_ID)
        return True
    except Exception as e:
        logging.error(f"Ошибка обновления данных пользователя: {e}")
        return False

