# Функция инициализации Redis (вызывается асинхронно при старте)
async def init_redis_client():
    """Инициализирует Redis клиент если REDIS_URL задан. Возвращает True если Redis успешно подключён."""
    global _redis_client
    if not REDIS_URL:
        return False
    try:
        import redis.asyncio as _redis_lib
        _redis_client = _redis_lib.from_url(REDIS_URL, decode_responses=False)
        # Проверяем подключение к Redis
        await _redis_client.ping()
        logging.info("🔴 Redis подключён успешно")
        return True
    except Exception as e:
        logging.warning(f"⚠️ Не удалось подключиться к Redis: {e}")
        _redis_client = None
        return False

{# Кастомное FSM-хранилище на основе PostgreSQL #}
# Кастомное хранилище FSM на основе PostgreSQL (bot_users.user_data JSONB)
# Примечание: update_user_data_in_db определяется позже в файле — это нормально для Python
# (функция вызывается в runtime, не при определении класса)
class PostgresStorage(BaseStorage):
    """Хранит FSM состояния в поле user_data таблицы bot_users."""

    async def set_state(self, key: StorageKey, state: StateType = None) -> None:
        uid = key.user_id
        val = state.state if state else None
        if uid not in user_data:
            user_data[uid] = {}
        user_data[uid]["__fsm_state__"] = val
        try:
            await update_user_data_in_db(uid, "__fsm_state__", val)
        except Exception:
            pass

    async def get_state(self, key: StorageKey) -> str | None:
        uid = key.user_id
        return user_data.get(uid, {}).get("__fsm_state__")

    async def set_data(self, key: StorageKey, data: dict) -> None:
        uid = key.user_id
        import json as _j
        val = _j.dumps(data, ensure_ascii=False)
        if uid not in user_data:
            user_data[uid] = {}
        user_data[uid]["__fsm_data__"] = val
        try:
            await update_user_data_in_db(uid, "__fsm_data__", val)
        except Exception:
            pass

    async def get_data(self, key: StorageKey) -> dict:
        uid = key.user_id
        raw = user_data.get(uid, {}).get("__fsm_data__", "{}")
        try:
            import json as _j
            return _j.loads(raw) if raw else {}
        except Exception:
            return {}

    async def close(self) -> None:
        pass

